# Lokal geliştirme — kendi değerlerinle .env olarak kopyala
DATABASE_URL=postgres://postgres@localhost:5432/teachernow_dev
# Test koşucusu yeni veritabanları yaratabilmek için süper-yetkili bağlantı ister
DATABASE_ADMIN_URL=postgres://postgres@localhost:5432/postgres
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SENTRY_DSN=

# --- web (S1 kabuk) ---
# better-auth oturum imzalama sırrı — üret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=degistir-beni
BETTER_AUTH_URL=http://localhost:3010
NEXT_PUBLIC_BASE_URL=http://localhost:3010
# Sosyal girisler yalniz anahtarlar varsa aktiflesir (opsiyonel)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#MICROSOFT_CLIENT_ID=
#MICROSOFT_CLIENT_SECRET=

# --- bildirimler (worker outbox dispatcher) ---
# Anahtar girilene kadar e-postalar notification_outbox'ta 'pending' birikir; anahtar gelince akar
#RESEND_API_KEY=
#MAIL_FROM=Teachernow <noreply@teachernow.app>
