{
  "name": "teachernow",
  "private": true,
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "db:migrate": "pnpm --filter @teachernow/db migrate",
    "db:check": "pnpm --filter @teachernow/db check",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r test",
    "lint:boundaries": "dependency-cruiser --config .dependency-cruiser.cjs packages apps",
    "lint:pii": "node tools/pii-linter.mjs",
    "probe": "node tools/synthetic-probe.mjs"
  },
  "devDependencies": {
    "dependency-cruiser": "^16.10.0",
    "typescript": "^5.6.3"
  }
}
